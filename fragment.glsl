void main() {
  vec2 t = texture_coordinates;
  t.y = 1 - t.y; // flipping the y-value because OpenGL stores textures upside down
  colour.rgb = colours[int(255*texture(texture, t).r)].rgb / 255; // indexing the colours array using the red value of the texture at that point as the index
  colour.a = 1;
}
